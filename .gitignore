# Decompiled game source — reference only, not part of the build
HoF-Decompiled/
hof-firstpass/

# .NET build output
bin/
obj/
*.user
*.suo

# Release staging + zips (assembled by release.ps1)
/release/

# C/C++ build intermediates (e.g. vendored Tolk source tree)
*.obj
*.exp
*.res

# FMOD SDK: license-gated, not redistributable as source/SDK, so vendored locally
# (see third_party/fmod/README.md) rather than committed. The runtime dll still ships
# inside the release zip, which is permitted product redistribution. The folder's
# README and the SDK LICENSE.TXT stay tracked.
third_party/fmod/lib/x86/fmod.dll
third_party/fmod/binding/*.cs

# Local Claude settings (machine paths, local permission grants)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# IDE
.vs/
.idea/

# Python bytecode cache (audio-demo generator scripts)
__pycache__/
*.pyc

# Audio working files at the repo root: reference samples being copied (often
# license-restricted, e.g. the zapsplat locator beep) and offline synth previews.
# Shipped sounds live in the plugin's sounds folder, which stays tracked.
/*.wav
/*.mp3
/*.ogg

# OS cruft
Thumbs.db
desktop.ini
.DS_Store
game-locales/
translation-work/
