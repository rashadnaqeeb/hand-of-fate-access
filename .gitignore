# Decompiled game source — reference only, not part of the build
HoF-Decompiled/
hof-firstpass/

# .NET build output
bin/
obj/
*.user
*.suo

# C/C++ build intermediates (e.g. vendored Tolk source tree)
*.obj
*.exp
*.res

# Local Claude settings (machine paths, local permission grants)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# IDE
.vs/
.idea/

# Python bytecode cache (audio-demo generator scripts)
__pycache__/
*.pyc

# Audio working files at the repo root: reference samples being copied (often
# license-restricted, e.g. the zapsplat locator beep) and offline synth previews.
# Shipped sounds live in the plugin's sounds folder, which stays tracked.
/*.wav

# OS cruft
Thumbs.db
desktop.ini
.DS_Store
